---
import Logo from '../../assets/icons/logo.svg';
---

<footer class="bg-white py-12 sm:py-16 md:py-20 relative">
  <div class="container mx-auto px-4 sm:px-6 md:px-8">
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 sm:gap-14 md:gap-16 mb-12 sm:mb-14 md:mb-16">
      
      <!-- Brand -->
      <div class="max-w-sm flex flex-col gap-3 sm:gap-4">
        <a href="/"><img src={Logo.src} alt="MySubs Logo" class="w-24 sm:w-28 md:w-32"></a>
        <p class="font-sans italic text-lg sm:text-xl text-[#404d60]">
          L'application gratuite qui simplie ta gestion d'abonnements.
        </p>
      </div>
      <!-- Navigation Links -->
      <div class="flex flex-wrap gap-12 sm:gap-16 lg:gap-24 xl:gap-32">
        
        <!-- Navigation -->
        <div>
          <h4 class="font-sans font-bold text-xl sm:text-2xl text-black mb-4 sm:mb-5 md:mb-6">Navigation</h4>
          <ul class="space-y-3 sm:space-y-4 font-sans font-medium text-lg sm:text-xl text-[#384961]">
            <li><a href="#features" class="hover:text-primary transition-colors">Fonctionnalités</a></li>
            <li><a href="#about" class="hover:text-primary transition-colors">À propos</a></li>
            <li><a href="#pricing" class="hover:text-primary transition-colors">Tarifs</a></li>
            <li><a href="#login" class="hover:text-primary transition-colors">Se connecter</a></li>
          </ul>
        </div>

        <!-- Légalités -->
        <div>
          <h4 class="font-sans font-bold text-xl sm:text-2xl text-black mb-4 sm:mb-5 md:mb-6">Légalités</h4>
          <ul class="space-y-3 sm:space-y-4 font-sans font-medium text-lg sm:text-xl text-[#384961]">
            <li><a href="#" class="hover:text-primary transition-colors">Mentions Légales</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Confidentialité</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">CGV</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">CGU</a></li>
          </ul>
        </div>

        <!-- Ressources -->
        <div>
          <h4 class="font-sans font-bold text-xl sm:text-2xl text-black mb-4 sm:mb-5 md:mb-6">Ressources</h4>
          <ul class="space-y-3 sm:space-y-4 font-sans font-medium text-lg sm:text-xl text-[#384961]">
            <li><a href="#" class="hover:text-primary transition-colors">Noter MySubs</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Télécharger sur Google Play</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Recommander un abonnement</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Importer mes données</a></li>
          </ul>
        </div>

      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-gray-200 mb-6 sm:mb-7 md:mb-8"></div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 sm:gap-7 md:gap-8">
      
      <!-- Social Icons -->
      <div class="flex gap-6 sm:gap-7 md:gap-8">
        <a href="https://instagram.com" class="w-6 h-6 sm:w-7 sm:h-7 opacity-70 hover:opacity-100 transition-opacity text-primary" rel="noopener noreferrer" target="_blank" aria-label="Suivre MySubs sur Instagram">
          <svg class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://x.com" class="w-6 h-6 sm:w-7 sm:h-7 opacity-70 hover:opacity-100 transition-opacity text-primary" rel="noopener noreferrer" target="_blank" aria-label="Suivre MySubs sur X (Twitter)">
          <svg class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://facebook.com" class="w-6 h-6 sm:w-7 sm:h-7 opacity-70 hover:opacity-100 transition-opacity text-primary" rel="noopener noreferrer" target="_blank" aria-label="Suivre MySubs sur Facebook">
          <svg class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>

      <!-- Bottom Links -->
      <div class="flex flex-wrap justify-center gap-6 sm:gap-8 md:gap-10 font-sans font-semibold text-lg sm:text-xl text-[#a6a6a6]">
        <a href="#" class="hover:text-primary transition-colors">Documentation</a>
        <a href="#" class="hover:text-primary transition-colors">Support</a>
        <a href="#" class="hover:text-primary transition-colors">FAQ</a>
      </div>

    </div>
  </div>
</footer>
