---
import Navbar from './Navbar.astro';
import Btn from '../ui/Btn.astro';
import Cercle from '../../assets/img/cercle.svg';
import MockUp from '../../assets/img/mock-up-hero.webp';
---

<header class="relative bg-secondary lg:min-h-screen overflow-hidden" role="banner">
  <Navbar />
  
  <!-- Background decorative circles -->
  <img 
    src={Cercle.src} 
    alt="" 
    class="absolute w-[120px] sm:w-[160px] md:w-[200px] lg:w-[780px] xl:w-[1100px] right-0 top-0" 
    data-speed="0.3"
    aria-hidden="true"
    width="1100"
    height="1100"
    loading="eager"
  />

  <div class="container mx-auto px-4 sm:px-6 md:px-8 pt-24 sm:pt-32 md:pt-40 lg:pt-56 xl:pt-72 pb-20 flex flex-col lg:flex-row items-start relative z-10">
    
    <!-- Hero content -->
    <section class="w-full lg:w-1/2 text-center lg:text-left mb-16 lg:mb-0 lg:-ml-8 xl:-ml-12">
      <h1 class="animate-on-scroll font-semibold text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-primary leading-tight mb-4 sm:mb-6 lg:mb-8">
        Gère facilement tes abonnements et anticipe tes dépenses
      </h1>
      <p class="animate-on-scroll delay-100 font-sans font-semibold text-base sm:text-lg md:text-xl lg:text-xl lg:mb-10 text-text-light mb-8 sm:mb-10 max-w-2xl mx-auto lg:mx-0">
        Avec MySubs, regroupe tous tes abonnements et reçoit des alertes avant chaque prélèvement. Ne subis plus jamais tes dépenses : maîtrise-les !
      </p>
      
      <div class="animate-on-scroll delay-200 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start">
        <Btn text="Essayer gratuitement" variant="default" href="#download" />
        <Btn text="Découvrir les fonctionnalités" variant="outline" href="#features" />
      </div>
    </section>

    <!-- Hero image -->
    <aside class="lg:flex w-full lg:absolute lg:w-[650px] xl:w-[1100px] items-center justify-center lg:right-[-100px] xl:right-[-160px] lg:top-52 xl:top-44" aria-label="Aperçu de l'application MySubs">
      <img 
        src={MockUp.src} 
        alt="Interface de l'application MySubs affichant le tableau de bord de gestion d'abonnements avec calendrier et statistiques" 
        class="float-animation w-full lg:w-[1200px] xl:w-[2000px] h-auto relative z-10"
        width="2000"
        height="1400"
        loading="eager"
      />
    </aside>
  </div>
</header>
