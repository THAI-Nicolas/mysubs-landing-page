---
import CreditAgricole from '../../assets/icons/credit-agricole.webp';
import Revolut from '../../assets/icons/revolut.webp';
import Unidays from '../../assets/icons/unidays.webp';
import Spotify from '../../assets/icons/spotify.webp';
import Notion from '../../assets/icons/notion.webp';
---

<section class="w-full py-12 sm:py-16 md:py-20 bg-gradient-primary overflow-hidden" aria-label="Partenaires et services compatibles">
  <div class="slider-container relative">
    <div class="slider-track flex items-center gap-16 sm:gap-20 md:gap-24 lg:gap-32 xl:gap-60">
      <img src={CreditAgricole.src} alt="Crédit Agricole" class="h-10 sm:h-12 md:h-16 lg:h-20 xl:h-26 object-contain" width="104" height="40" loading="lazy" />
      <img src={Revolut.src} alt="Revolut" class="h-8 sm:h-10 md:h-14 lg:h-18 xl:h-22 object-contain" width="88" height="32" loading="lazy" />
      <img src={Unidays.src} alt="UNiDAYS" class="h-6 sm:h-7 md:h-8 lg:h-9 xl:h-10 object-contain" width="80" height="24" loading="lazy" />
      <img src={Spotify.src} alt="Spotify" class="h-10 sm:h-12 md:h-16 lg:h-20 xl:h-26 object-contain" width="104" height="40" loading="lazy" />
      <img src={Notion.src} alt="Notion" class="h-10 sm:h-12 md:h-16 lg:h-20 xl:h-24 object-contain" width="96" height="40" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .slider-container {
    display: flex;
    width: 100%;
  }
  
  .slider-track {
    display: flex;
    align-items: center;
    will-change: transform;
  }
  
  .slider-track img {
    transition: opacity 0.3s, filter 0.3s;
    object-fit: contain;
  }
</style>