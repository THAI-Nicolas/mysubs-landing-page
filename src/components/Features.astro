---
// Features component - Matching Figma design
const features = [
  {
    icon: "📊",
    title: "Vue d'ensemble complète",
    description: "Visualisez tous vos abonnements en un coup d'œil avec un tableau de bord intuitif"
  },
  {
    icon: "🔔",
    title: "Notifications intelligentes",
    description: "Recevez des alertes avant chaque renouvellement pour ne jamais être surpris"
  },
  {
    icon: "💰",
    title: "Suivi des dépenses",
    description: "Analysez vos dépenses mensuelles et annuelles avec des graphiques détaillés"
  },
  {
    icon: "📅",
    title: "Calendrier intégré",
    description: "Consultez tous vos renouvellements dans un calendrier pratique"
  },
  {
    icon: "🏷️",
    title: "Catégories personnalisées",
    description: "Organisez vos abonnements par catégorie pour une meilleure gestion"
  },
  {
    icon: "🔒",
    title: "Données sécurisées",
    description: "Vos informations sont chiffrées et stockées en toute sécurité"
  }
];
---

<section id="features" class="py-16 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">
        Fonctionnalités puissantes
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Tout ce dont vous avez besoin pour gérer vos abonnements efficacement
      </p>
    </div>
    
    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {features.map((feature) => (
        <div class="bg-white border border-gray-200 rounded-xl p-6 lg:p-8 hover:shadow-lg hover:border-primary/30 transition-all duration-300">
          <div class="w-12 h-12 bg-yellow-50 rounded-lg flex items-center justify-center mb-4">
            <span class="text-3xl">{feature.icon}</span>
          </div>
          <h3 class="text-lg lg:text-xl font-bold text-gray-900 mb-2">{feature.title}</h3>
          <p class="text-gray-600 text-sm lg:text-base leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
