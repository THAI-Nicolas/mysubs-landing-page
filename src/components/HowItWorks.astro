---
// How it works section - Matching Figma design
const steps = [
  {
    number: "1",
    title: "Ajoutez vos abonnements",
    description: "Entrez facilement vos abonnements avec leur nom, prix et date de renouvellement"
  },
  {
    number: "2",
    title: "Recevez des notifications",
    description: "Soyez alerté avant chaque renouvellement pour éviter les mauvaises surprises"
  },
  {
    number: "3",
    title: "Optimisez vos dépenses",
    description: "Analysez vos dépenses et identifiez les abonnements inutilisés"
  }
];
---

<section class="py-16 lg:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">
        Comment ça marche ?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Commencez à gérer vos abonnements en 3 étapes simples
      </p>
    </div>
    
    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step) => (
        <div class="text-center">
          <!-- Step number -->
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary text-white rounded-full text-2xl font-bold mb-6 shadow-lg">
            {step.number}
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-3">{step.title}</h3>
          <p class="text-gray-600 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
