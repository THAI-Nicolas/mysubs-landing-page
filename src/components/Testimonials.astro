---
// Testimonials section
const testimonials = [
  {
    name: "Marie Dubois",
    role: "Étudiante",
    content: "MySubs m'a permis de reprendre le contrôle de mes finances. Je ne rate plus aucun renouvellement !",
    rating: 5
  },
  {
    name: "Thomas Martin",
    role: "Développeur",
    content: "Interface intuitive et fonctionnalités complètes. Exactement ce dont j'avais besoin.",
    rating: 5
  },
  {
    name: "Sophie Lefebvre",
    role: "Chef d'entreprise",
    content: "J'ai économisé plus de 200€ par mois en identifiant les abonnements que je n'utilisais plus.",
    rating: 5
  }
];
---

<section class="py-20 bg-primary-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
        Ils utilisent MySubs
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Découvrez ce que nos utilisateurs pensent de l'application
      </p>
    </div>
    
    <!-- Testimonials grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <!-- Rating -->
          <div class="flex mb-4">
            {[...Array(testimonial.rating)].map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          
          <!-- Content -->
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "{testimonial.content}"
          </p>
          
          <!-- Author -->
          <div>
            <div class="font-bold text-gray-900">{testimonial.name}</div>
            <div class="text-gray-600 text-sm">{testimonial.role}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
