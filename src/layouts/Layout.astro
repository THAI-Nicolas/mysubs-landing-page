---
import '../styles/global.css';
import '../styles/animations.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { 
  title, 
  description = "Gère tous tes abonnements facilement : alertes avant prélèvement, calcul automatique de tes dépenses et accès à plus de 120 services. Fini les mauvaises surprises.", 
  ogImage = "/og-image.jpg",
  canonicalUrl = "https://mysubs.app"
} = Astro.props;

const fullOgImageUrl = new URL(ogImage, Astro.site || "https://mysubs.app").href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="MySubs" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Fonts - Urbanist with font-display swap -->
    <link 
      href="https://fonts.googleapis.com/css2?family=Urbanist:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" 
      rel="stylesheet" 
    />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MySubs" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="MySubs - Gestionnaire d'abonnements" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mysubs_app" />
    <meta name="twitter:creator" content="@mysubs_app" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImageUrl} />
    <meta name="twitter:image:alt" content="MySubs - Gestionnaire d'abonnements" />
    
    <!-- JSON-LD Structured Data - Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "MySubs",
        "url": "https://mysubs.app",
        "logo": "https://mysubs.app/logo.png",
        "description": "Application de gestion d'abonnements pour suivre et optimiser vos dépenses mensuelles",
        "sameAs": [
          "https://www.instagram.com/mysubs_app",
          "https://twitter.com/mysubs_app",
          "https://www.facebook.com/mysubs"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "Customer Support",
          "email": "support@mysubs.app"
        }
      }
    </script>
    
    <!-- JSON-LD Structured Data - WebSite -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "MySubs",
        "url": "https://mysubs.app",
        "description": "Gestionnaire d'abonnements intelligent",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://mysubs.app/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    
    <!-- JSON-LD Structured Data - SoftwareApplication -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "MySubs",
        "operatingSystem": ["iOS", "Android"],
        "applicationCategory": "FinanceApplication",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.8",
          "ratingCount": "1250",
          "bestRating": "5",
          "worstRating": "1"
        },
        "description": "Application gratuite de gestion d'abonnements avec alertes automatiques, statistiques détaillées et catalogue de plus de 120 services"
      }
    </script>
  </head>
  <body class="antialiased font-sans">
    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded">
      Aller au contenu principal
    </a>
    
    <slot />
  </body>
  <script>
    // Import et initialisation des animations
    const initAnimations = async () => {
      try {
        const module = await import('../scripts/animations.js');
        console.log('✨ Animations loaded');
      } catch (error) {
        console.error('Error loading animations:', error);
      }
    };
    
    initAnimations();
  </script>
</html>
